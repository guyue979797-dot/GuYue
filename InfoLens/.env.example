# 公网域名（不要包含 http:// 或路径）
INFOLENS_DOMAIN=infolens.example.com

# production 环境禁止使用 off。初次部署可选 password，公司 SSO 使用 oidc。
INFOLENS_AUTH_MODE=password
INFOLENS_SESSION_SECRET=replace-with-at-least-32-random-bytes

# password 模式
INFOLENS_USERNAME=admin
INFOLENS_PASSWORD_HASH=replace-with-werkzeug-password-hash

# oidc 模式（接入公司 Microsoft Entra ID 或其他标准 OIDC 服务时填写）
# INFOLENS_OIDC_METADATA_URL=https://login.example.com/.well-known/openid-configuration
# INFOLENS_OIDC_CLIENT_ID=
# INFOLENS_OIDC_CLIENT_SECRET=
# INFOLENS_ALLOWED_EMAIL_DOMAIN=example.com
# INFOLENS_ALLOWED_EMAILS=user1@example.com,user2@example.com

# CRM 配置
INFOLENS_CRM_SECRET_KEY=replace-with-rotated-crm-secret
INFOLENS_CRM_BASE_URL=https://crm.crb.cn/kan-appserver
INFOLENS_COS_BASE_URL=https://sfa-prd-1259627966.cos.ap-chengdu.myqcloud.com/

# 单个账号在时间窗口内最多提取次数
INFOLENS_RATE_LIMIT=10
INFOLENS_RATE_WINDOW_SECONDS=600
