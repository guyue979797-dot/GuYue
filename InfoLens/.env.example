# 公网域名（不要包含 http:// 或路径）
INFOLENS_DOMAIN=infolens.example.com

# production 环境禁止使用 off。初次部署可选 password，公司 SSO 使用 oidc。
INFOLENS_AUTH_MODE=password
INFOLENS_SESSION_SECRET=replace-with-at-least-32-random-bytes

# password 模式
# 超级管理员会在启动时自动创建/修复，不能被删除或禁用。
INFOLENS_SUPER_ADMIN_USERNAME=admin
INFOLENS_SUPER_ADMIN_PASSWORD_HASH=replace-with-werkzeug-password-hash
# 本地临时调试也可使用明文环境变量，生产环境建议只使用 HASH。
# INFOLENS_SUPER_ADMIN_PASSWORD=replace-with-strong-password
# 兼容旧配置：INFOLENS_USERNAME + INFOLENS_PASSWORD_HASH 仍会作为超级管理员账号导入。

# oidc 模式（接入公司 Microsoft Entra ID 或其他标准 OIDC 服务时填写）
# INFOLENS_OIDC_METADATA_URL=https://login.example.com/.well-known/openid-configuration
# INFOLENS_OIDC_CLIENT_ID=
# INFOLENS_OIDC_CLIENT_SECRET=
# INFOLENS_ALLOWED_EMAIL_DOMAIN=example.com
# INFOLENS_ALLOWED_EMAILS=user1@example.com,user2@example.com

# CRM 配置
INFOLENS_CRM_SECRET_KEY=replace-with-rotated-crm-secret
INFOLENS_CRM_BASE_URL=https://crm.crb.cn/kan-appserver
INFOLENS_COS_BASE_URL=https://sfa-prd-1259627966.cos.ap-chengdu.myqcloud.com/
INFOLENS_DOWNLOAD_ATTEMPTS=4
INFOLENS_CRM_ALLOW_LEGACY_RENEGOTIATION=true

# 批量提取：单次最多 500 条，每 50 条作为一个可恢复分段，单链接最多尝试 3 次。
INFOLENS_MAX_BATCH_LINKS=500
INFOLENS_BATCH_CHUNK_SIZE=50
INFOLENS_BATCH_LINK_ATTEMPTS=3

# 单个账号在时间窗口内最多提取次数
INFOLENS_RATE_LIMIT=10
INFOLENS_RATE_WINDOW_SECONDS=600

# 企业微信 API 模式智能机器人
WECOM_BOT_ENABLED=false
WECOM_BOT_MODE=long_connection
# WECOM_BOT_ID=在机器人详情页复制
# WECOM_BOT_SECRET=长连接模式的Secret
WECOM_BOT_MAX_LINKS=10
# 默认直连；如运行环境必须使用代理，再填写完整代理 URL
# WECOM_BOT_PROXY=

# 仅 URL 回调模式需要以下配置；没有域名时无需填写
# WECOM_BOT_MODE=callback
# WECOM_BOT_TOKEN=创建机器人时配置的Token
# WECOM_BOT_ENCODING_AES_KEY=创建机器人时配置的43位EncodingAESKey
WECOM_BOT_CALLBACK_MAX_AGE_SECONDS=600
WECOM_BOT_RESPONSE_HOSTS=qyapi.weixin.qq.com
# 本地开发默认仅允许本机访问；部署时由反向代理或容器显式覆盖。
INFOLENS_HOST=127.0.0.1
INFOLENS_PORT=8765
